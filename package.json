{
  "name": "codexblo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser ARPG prototype focused on dungeon-first vertical slices.",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0",
