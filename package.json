    "generate:assets": "node scripts/generate-cathedral-assets.mjs",
    "check": "npm run generate:assets && npm test && npm run build"
  },
  "dependencies": {
    "phaser": "4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "25.9.3",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
